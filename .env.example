SECRET_KEY=replace-with-long-random-secret-key-min-32-chars
DATABASE_URL=sqlite:///database/site.db
SQLALCHEMY_TRACK_MODIFICATIONS=false

DEFAULT_ADMIN_USERNAME=site_admin
DEFAULT_ADMIN_PASSWORD=replace-with-strong-admin-password

FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=1048576
LOG_BACKUP_COUNT=5
LOG_TO_CONSOLE=false
PII_LOGGING_ENABLED=false
RATELIMIT_STORAGE_URI=memory://

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_SECURE=true
REMEMBER_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_MINUTES=480
SECURITY_HEADERS_ENABLED=true
